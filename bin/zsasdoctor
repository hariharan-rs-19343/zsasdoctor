#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
#  zsasdoctor — SAS Developer Environment Doctor Tool
# ─────────────────────────────────────────────────────────────
set -uo pipefail

# ── Resolve script root ──────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# ── Source modules ───────────────────────────────────────────
source "$ROOT_DIR/config/constants.sh"
source "$ROOT_DIR/lib/logger.sh"
source "$ROOT_DIR/lib/utils.sh"
source "$ROOT_DIR/lib/java.sh"
source "$ROOT_DIR/lib/database.sh"
source "$ROOT_DIR/lib/ant.sh"
source "$ROOT_DIR/lib/intranet.sh"

# ── Commands ─────────────────────────────────────────────────

cmd_check() {
    echo ""
    printf "  ${_CLR_BOLD}${ZSASDOCTOR_NAME} v${ZSASDOCTOR_VERSION}${_CLR_RESET} ${_CLR_DIM}— Environment Check${_CLR_RESET}\n"
    echo ""

    check_java      || true
    check_database   || true
    check_ant        || true
    check_intranet   || true

    print_final_status
}

cmd_config() {
    local target=""
    local args=("$@")

    # Parse flags
    for arg in "${args[@]}"; do
        case "$arg" in
            -f|--force)  FORCE_MODE=1 ;;
            --yes)       SKIP_CONFIRM=1 ;;
            --*)         target="$arg" ;;
        esac
    done

    if [[ -z "$target" ]]; then
        printf "  ${_CLR_RED}✗${_CLR_RESET} No config target specified\n"
        echo ""
        echo "  Usage:"
        echo "    zsasdoctor config [--auto|--java|--database|--ant|--intranet]"
        echo "    zsasdoctor config -f --auto       Force reinstall all"
        echo "    zsasdoctor config -f --java       Force reinstall Java"
        echo "    zsasdoctor config -f --yes --auto Skip confirmations"
        return "$EXIT_FAIL"
    fi

    echo ""
    if (( FORCE_MODE )); then
        printf "  ${_CLR_BOLD}${ZSASDOCTOR_NAME} v${ZSASDOCTOR_VERSION}${_CLR_RESET} ${_CLR_RED}${_CLR_BOLD}— Force Configuration${_CLR_RESET}\n"
    else
        printf "  ${_CLR_BOLD}${ZSASDOCTOR_NAME} v${ZSASDOCTOR_VERSION}${_CLR_RESET} ${_CLR_DIM}— Auto Configuration${_CLR_RESET}\n"
    fi
    echo ""

    case "$target" in
        --auto)
            if (( FORCE_MODE )); then
                force_java
                force_database
                force_ant
            else
                fix_java
                fix_database
                fix_ant
            fi
            check_intranet || fix_intranet
            ;;
        --java)
            if (( FORCE_MODE )); then force_java; else fix_java; fi
            ;;
        --database)
            if (( FORCE_MODE )); then force_database; else fix_database; fi
            ;;
        --ant)
            if (( FORCE_MODE )); then force_ant; else fix_ant; fi
            ;;
        --intranet)
            fix_intranet
            ;;
        *)
            printf "  ${_CLR_RED}✗${_CLR_RESET} Unknown config target: ${target}\n"
            echo ""
            echo "  Usage:"
            echo "    zsasdoctor config --auto        Run all fixes"
            echo "    zsasdoctor config -f --auto     Force reinstall all"
            echo "    zsasdoctor config --java        Install/configure Java"
            echo "    zsasdoctor config --database    Install/configure database"
            echo "    zsasdoctor config --ant         Install/configure Ant"
            echo "    zsasdoctor config --intranet    Configure intranet access"
            return "$EXIT_FAIL"
            ;;
    esac

    print_final_status
}

cmd_version() {
    echo "${ZSASDOCTOR_NAME} v${ZSASDOCTOR_VERSION}"
}

cmd_help() {
    cat <<EOF
${ZSASDOCTOR_NAME} v${ZSASDOCTOR_VERSION}
SAS Developer Environment Doctor Tool

Usage:
  zsasdoctor <command> [options]

Commands:
  check                          Validate local environment
  config --auto                  Auto-fix all issues
  config --java                  Install/configure Java
  config --database              Install/configure database
  config --ant                   Install/configure Ant
  config --intranet              Show intranet connectivity guidance
  config -f --auto               Force reinstall all components
  config -f --java               Force reinstall Java
  config -f --database           Force reinstall database
  config -f --ant                Force reinstall Ant
  version                        Print version
  help                           Show this help

Flags:
  -f, --force    Force reinstall even if already present
  --yes          Skip confirmation prompts (use with -f)

Exit Codes:
  0   All checks passed
  1   Validation failed
  2   Partial success (warnings only)
  127 Dependency missing
EOF
}

# ── Main dispatcher ──────────────────────────────────────────
main() {
    local command="${1:-help}"
    shift || true

    case "$command" in
        check)    cmd_check ;;
        config)   cmd_config "$@" ;;
        version)  cmd_version ;;
        help|--help|-h)  cmd_help ;;
        *)
            log_error "Unknown command: ${command}"
            cmd_help
            exit "$EXIT_FAIL"
            ;;
    esac
}

main "$@"
